{
  "datasets": [
    {
      "name": "ds_kpis_24h",
      "displayName": "KPIs 24h",
      "query": "SELECT\n    MEASURE(preco_fechamento)        AS ultimo_preco,\n    MEASURE(retorno_periodo)         AS variacao_24h_pct,\n    MEASURE(volume_usd)              AS volume_24h_usd,\n    MEASURE(pressao_compradora_pct)  AS pressao_compra_pct,\n    MEASURE(pressao_vendedora_pct)   AS pressao_venda_pct,\n    MEASURE(qtd_trades)              AS trades_24h\nFROM z_bitcoin.gold.mtv_btc_intraday\nWHERE ts_5m >= CURRENT_TIMESTAMP() - INTERVAL 24 HOUR"
    },
    {
      "name": "ds_preco_timeline",
      "displayName": "Preco Timeline (Historico + Forecast)",
      "query": "WITH historico AS (\n    SELECT\n        ts_15m AS ts,\n        'Historico' AS tipo_dado,\n        MEASURE(preco_fechamento) AS preco,\n        CAST(NULL AS DOUBLE) AS limite_inferior,\n        CAST(NULL AS DOUBLE) AS limite_superior\n    FROM z_bitcoin.gold.mtv_btc_intraday\n    WHERE ts_15m >= CURRENT_TIMESTAMP() - INTERVAL 7 DAY\n    GROUP BY ALL\n),\nforecast AS (\n    SELECT\n        forecast_ts_15m AS ts,\n        'Previsao' AS tipo_dado,\n        MEASURE(preco_previsto) AS preco,\n        MEASURE(limite_inferior_95) AS limite_inferior,\n        MEASURE(limite_superior_95) AS limite_superior\n    FROM z_bitcoin.gold.mtv_btc_forecast\n    GROUP BY ALL\n)\nSELECT * FROM historico\nUNION ALL\nSELECT * FROM forecast\nORDER BY ts"
    },
    {
      "name": "ds_fluxo_compra_venda",
      "displayName": "Fluxo Compra vs Venda",
      "query": "SELECT\n    ts_15m,\n    MEASURE(volume_compra)  AS volume_compra,\n    MEASURE(volume_venda)   AS volume_venda,\n    MEASURE(volume_compra) - MEASURE(volume_venda) AS pressao_liquida\nFROM z_bitcoin.gold.mtv_btc_intraday\nWHERE ts_15m >= CURRENT_TIMESTAMP() - INTERVAL 24 HOUR\nGROUP BY ALL\nORDER BY ts_15m"
    },
    {
      "name": "ds_rolling_summary",
      "displayName": "Tabela Rolling",
      "query": "WITH janelas AS (\n    SELECT '10min' AS janela, 10 AS minutos, 1 AS ordem UNION ALL\n    SELECT '20min', 20, 2 UNION ALL\n    SELECT '1h', 60, 3 UNION ALL\n    SELECT '4h', 240, 4 UNION ALL\n    SELECT '1d', 1440, 5\n),\ndados AS (\n    SELECT\n        ts_5m,\n        MEASURE(preco_abertura)   AS abertura,\n        MEASURE(preco_fechamento) AS fechamento,\n        MEASURE(volume_btc)       AS volume\n    FROM z_bitcoin.gold.mtv_btc_intraday\n    WHERE ts_5m >= CURRENT_TIMESTAMP() - INTERVAL 1 DAY\n    GROUP BY ALL\n)\nSELECT\n    j.janela,\n    MIN(d.abertura) AS abertura_usd,\n    MAX(d.fechamento) AS atual_usd,\n    (MAX(d.fechamento) - MIN(d.abertura)) / NULLIF(MIN(d.abertura), 0) * 100 AS variacao_pct,\n    SUM(d.volume) AS volume_btc,\n    CASE\n        WHEN MAX(d.fechamento) > MIN(d.abertura) * 1.001 THEN 'Alta'\n        WHEN MAX(d.fechamento) < MIN(d.abertura) * 0.999 THEN 'Queda'\n        ELSE 'Estavel'\n    END AS resultado\nFROM janelas j\nCROSS JOIN dados d\nWHERE d.ts_5m >= CURRENT_TIMESTAMP() - MAKE_INTERVAL(0, 0, 0, 0, 0, j.minutos)\nGROUP BY j.janela, j.minutos, j.ordem\nORDER BY j.ordem"
    }
  ],
  "pages": [
    {
      "name": "main_page",
      "displayName": "PAINEL - Bitcoin (BTC)",
      "layout": [
        {
          "widget": {
            "name": "kpi_ultimo_preco",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_kpis_24h",
                  "fields": [
                    {"name": "ultimo_preco", "expression": "`ultimo_preco`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "ultimo_preco", "displayName": "Ultimo Preco (USD)"}
              },
              "frame": {
                "showTitle": true,
                "title": "Ultimo Preco (USD)"
              }
            }
          },
          "position": {"x": 0, "y": 0, "width": 1, "height": 2}
        },
        {
          "widget": {
            "name": "kpi_variacao_24h",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_kpis_24h",
                  "fields": [
                    {"name": "variacao_24h_pct", "expression": "`variacao_24h_pct`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "variacao_24h_pct", "displayName": "Variacao 24h (%)"}
              },
              "frame": {
                "showTitle": true,
                "title": "Variacao 24h (%)"
              }
            }
          },
          "position": {"x": 1, "y": 0, "width": 1, "height": 2}
        },
        {
          "widget": {
            "name": "kpi_volume_24h",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_kpis_24h",
                  "fields": [
                    {"name": "volume_24h_usd", "expression": "`volume_24h_usd`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "volume_24h_usd", "displayName": "Volume 24h (USD)"}
              },
              "frame": {
                "showTitle": true,
                "title": "Volume 24h (USD)"
              }
            }
          },
          "position": {"x": 2, "y": 0, "width": 1, "height": 2}
        },
        {
          "widget": {
            "name": "kpi_pressao",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_kpis_24h",
                  "fields": [
                    {"name": "pressao_compra_pct", "expression": "`pressao_compra_pct`"},
                    {"name": "pressao_venda_pct", "expression": "`pressao_venda_pct`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "pressao_compra_pct", "displayName": "Pressao Compra (%)"}
              },
              "frame": {
                "showTitle": true,
                "title": "Pressao Compra/Venda 24h"
              }
            }
          },
          "position": {"x": 3, "y": 0, "width": 1, "height": 2}
        },
        {
          "widget": {
            "name": "chart_preco_timeline",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_preco_timeline",
                  "fields": [
                    {"name": "ts", "expression": "`ts`"},
                    {"name": "tipo_dado", "expression": "`tipo_dado`"},
                    {"name": "preco", "expression": "`preco`"},
                    {"name": "limite_inferior", "expression": "`limite_inferior`"},
                    {"name": "limite_superior", "expression": "`limite_superior`"}
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "line",
              "encodings": {
                "x": {
                  "fieldName": "ts",
                  "scale": {"type": "temporal"},
                  "displayName": "Data/Hora"
                },
                "y": {
                  "fieldName": "preco",
