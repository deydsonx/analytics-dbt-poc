                  {"fieldName": "janela", "displayName": "Janela"},
                  {"fieldName": "abertura_usd", "displayName": "Abertura (USD)", "format": {"type": "currency", "currencyCode": "USD"}},
                  {"fieldName": "atual_usd", "displayName": "Atual (USD)", "format": {"type": "currency", "currencyCode": "USD"}},
                  {"fieldName": "variacao_pct", "displayName": "Variacao (%)", "format": {"type": "percent"}},
                  {"fieldName": "volume_btc", "displayName": "Volume (BTC)", "format": {"type": "number", "decimalPlaces": 4}},
                  {"fieldName": "resultado", "displayName": "Resultado"}
                ]
