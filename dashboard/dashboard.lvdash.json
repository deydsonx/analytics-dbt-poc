{
  "datasets": [
    {
      "name": "ds_granularidades",
      "displayName": "Opções de granularidade",
      "queryLines": [
        "SELECT * FROM VALUES ('1 minuto'), ('5 minutos'), ('10 minutos'), ('15 minutos'), ('30 minutos'), ('60 minutos') AS t(rotulo)"
      ]
    },
    {
      "name": "ds_periodos",
      "displayName": "Opções de período histórico",
      "queryLines": [
        "SELECT * FROM VALUES ('1 hora'), ('6 horas'), ('12 horas'), ('24 horas'), ('7 dias') AS t(rotulo)"
      ]
    },
    {
      "name": "ds_kpis",
      "displayName": "KPIs principais (24h)",
      "queryLines": [
        "WITH ult AS (  SELECT MAX_BY(price, trade_ts) AS ultimo_preco FROM z_bitcoin.gold.vw_trades_realtime WHERE trade_ts >= current_timestamp() - INTERVAL 2 DAYS), janela_24h AS (  SELECT    MIN_BY(price, trade_ts) AS preco_abertura_24h,    SUM(notional_usd) AS volume_24h_usd,    (SUM(CASE WHEN side='BUY' THEN quantity ELSE 0 END)     - SUM(CASE WHEN side='SELL' THEN quantity ELSE 0 END))     / NULLIF(SUM(quantity), 0) AS pressao_compra_venda  FROM z_bitcoin.gold.vw_trades_realtime  WHERE trade_ts >= current_timestamp() - INTERVAL 24 HOURS) SELECT  ult.ultimo_preco,  (ult.ultimo_preco - janela_24h.preco_abertura_24h) / NULLIF(janela_24h.preco_abertura_24h, 0) AS variacao_24h_pct,  janela_24h.volume_24h_usd,  janela_24h.pressao_compra_venda FROM ult, janela_24h"
      ]
    },
    {
      "name": "ds_serie_preco",
      "displayName": "Série de preço (realizado + previsto)",
      "queryLines": [
        "WITH gran AS (SELECT CASE :granularidade WHEN '1 minuto' THEN 60 WHEN '5 minutos' THEN 300 WHEN '10 minutos' THEN 600 WHEN '15 minutos' THEN 900 WHEN '30 minutos' THEN 1800 WHEN '60 minutos' THEN 3600 ELSE 300 END AS segundos), periodo AS (SELECT CASE :periodo WHEN '1 hora' THEN 1 WHEN '6 horas' THEN 6 WHEN '12 horas' THEN 12 WHEN '24 horas' THEN 24 WHEN '7 dias' THEN 168 ELSE 24 END AS horas), realizado AS (SELECT CAST(FROM_UNIXTIME(FLOOR(UNIX_TIMESTAMP(trade_ts) / (SELECT segundos FROM gran)) * (SELECT segundos FROM gran)) AS TIMESTAMP) AS ts, MAX_BY(price, trade_ts) AS preco_fechamento, SUM(notional_usd) / NULLIF(SUM(quantity), 0) AS vwap, CAST(NULL AS DOUBLE) AS previsao, CAST(NULL AS DOUBLE) AS banda_inferior, CAST(NULL AS DOUBLE) AS banda_superior FROM z_bitcoin.gold.vw_trades_realtime WHERE trade_ts >= dateadd(hour, -(SELECT horas FROM periodo), current_timestamp()) AND trade_ts <= current_timestamp() GROUP BY 1), previsto AS (SELECT ds AS ts, CAST(NULL AS DOUBLE) AS preco_fechamento, CAST(NULL AS DOUBLE) AS vwap, y_forecast AS previsao, y_lower AS banda_inferior, y_upper AS banda_superior FROM z_bitcoin.gold.f_forecast_5m WHERE ds > current_timestamp()) SELECT * FROM realizado UNION ALL SELECT * FROM previsto ORDER BY ts"
      ],
      "parameters": [
        {
          "displayName": "Granularidade",
          "keyword": "granularidade",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [{"value": "5 minutos"}]
            }
          }
        },
        {
          "displayName": "Período",
          "keyword": "periodo",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [{"value": "24 horas"}]
            }
          }
        }
      ]
    },
    {
      "name": "ds_compra_venda",
      "displayName": "Fluxo de compra e venda",
      "queryLines": [
        "WITH gran AS (SELECT CASE :granularidade WHEN '1 minuto' THEN 60 WHEN '5 minutos' THEN 300 WHEN '10 minutos' THEN 600 WHEN '15 minutos' THEN 900 WHEN '30 minutos' THEN 1800 WHEN '60 minutos' THEN 3600 ELSE 300 END AS segundos), periodo AS (SELECT CASE :periodo WHEN '1 hora' THEN 1 WHEN '6 horas' THEN 6 WHEN '12 horas' THEN 12 WHEN '24 horas' THEN 24 WHEN '7 dias' THEN 168 ELSE 24 END AS horas) SELECT CAST(FROM_UNIXTIME(FLOOR(UNIX_TIMESTAMP(trade_ts) / (SELECT segundos FROM gran)) * (SELECT segundos FROM gran)) AS TIMESTAMP) AS ts, SUM(CASE WHEN side='BUY' THEN quantity ELSE 0 END) AS volume_compra, -1 * SUM(CASE WHEN side='SELL' THEN quantity ELSE 0 END) AS volume_venda, SUM(CASE WHEN side='BUY' THEN quantity ELSE 0 END) - SUM(CASE WHEN side='SELL' THEN quantity ELSE 0 END) AS delta_liquido FROM z_bitcoin.gold.vw_trades_realtime WHERE trade_ts >= dateadd(hour, -(SELECT horas FROM periodo), current_timestamp()) AND trade_ts <= current_timestamp() GROUP BY 1 ORDER BY 1"
      ],
      "parameters": [
        {
          "displayName": "Granularidade",
          "keyword": "granularidade",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [{"value": "5 minutos"}]
            }
          }
        },
        {
          "displayName": "Período",
          "keyword": "periodo",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [{"value": "24 horas"}]
            }
          }
        }
      ]
    },
    {
      "name": "ds_distribuicao",
      "displayName": "Distribuição por janela (rolling)",
      "queryLines": [
        "WITH agora AS (SELECT MAX(trade_ts) AS ts_agora, MAX_BY(price, trade_ts) AS preco_atual FROM z_bitcoin.gold.vw_trades_realtime WHERE trade_ts >= current_timestamp() - INTERVAL 2 DAYS), base AS (SELECT '10 min' AS janela, 1 AS ordem, MIN_BY(t.price, t.trade_ts) AS preco_abertura, SUM(t.quantity) AS volume_btc FROM z_bitcoin.gold.vw_trades_realtime t CROSS JOIN agora a WHERE t.trade_ts >= dateadd(minute, -10, a.ts_agora) AND t.trade_ts >= current_timestamp() - INTERVAL 1 DAY UNION ALL SELECT '20 min', 2, MIN_BY(t.price, t.trade_ts), SUM(t.quantity) FROM z_bitcoin.gold.vw_trades_realtime t CROSS JOIN agora a WHERE t.trade_ts >= dateadd(minute, -20, a.ts_agora) AND t.trade_ts >= current_timestamp() - INTERVAL 1 DAY UNION ALL SELECT '1 hora', 3, MIN_BY(t.price, t.trade_ts), SUM(t.quantity) FROM z_bitcoin.gold.vw_trades_realtime t CROSS JOIN agora a WHERE t.trade_ts >= dateadd(minute, -60, a.ts_agora) AND t.trade_ts >= current_timestamp() - INTERVAL 1 DAY UNION ALL SELECT '4 horas', 4, MIN_BY(t.price, t.trade_ts), SUM(t.quantity) FROM z_bitcoin.gold.vw_trades_realtime t CROSS JOIN agora a WHERE t.trade_ts >= dateadd(minute, -240, a.ts_agora) AND t.trade_ts >= current_timestamp() - INTERVAL 1 DAY UNION ALL SELECT '1 dia', 5, MIN_BY(t.price, t.trade_ts), SUM(t.quantity) FROM z_bitcoin.gold.vw_trades_realtime t CROSS JOIN agora a WHERE t.trade_ts >= dateadd(day, -1, a.ts_agora) AND t.trade_ts >= current_timestamp() - INTERVAL 2 DAY) SELECT b.janela, b.ordem, b.preco_abertura, a.preco_atual, (a.preco_atual - b.preco_abertura) / NULLIF(b.preco_abertura, 0) AS variacao_pct, b.volume_btc, CASE WHEN a.preco_atual > b.preco_abertura THEN '▲ Alta' WHEN a.preco_atual < b.preco_abertura THEN '▼ Baixa' ELSE '─ Estável' END AS resultado FROM base b CROSS JOIN agora a ORDER BY b.ordem"
      ]
    }
  ],
