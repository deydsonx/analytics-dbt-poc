              }
            }
          },
          "position": {"x": 0, "y": 8, "width": 2, "height": 4}
        },
        {
          "widget": {
            "name": "table_rolling_summary",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_rolling_summary",
                  "fields": [
                    {"name": "janela", "expression": "`janela`"},
                    {"name": "abertura_usd", "expression": "`abertura_usd`"},
                    {"name": "atual_usd", "expression": "`atual_usd`"},
                    {"name": "variacao_pct", "expression": "`variacao_pct`"},
                    {"name": "volume_btc", "expression": "`volume_btc`"},
                    {"name": "resultado", "expression": "`resultado`"}
                  ],
