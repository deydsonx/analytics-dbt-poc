                    {"name": "ts_15m", "expression": "`ts_15m`"},
                    {"name": "volume_compra", "expression": "`volume_compra`"},
                    {"name": "volume_venda", "expression": "-`volume_venda`"},
                    {"name": "pressao_liquida", "expression": "`pressao_liquida`"}
