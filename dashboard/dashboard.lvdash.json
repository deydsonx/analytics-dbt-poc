                  "displayName": "Preco (USD)"
                },
                "color": {
                  "fieldName": "tipo_dado",
                  "scale": {
                    "domain": ["Historico", "Previsao"],
                    "range": ["#2196F3", "#FF9800"]
                  },
                  "legend": {"title": "Serie"}
                }
              },
              "frame": {
                "showTitle": true,
                "title": "Preco BTC - Realizado e Previsto (24h)"
              }
            }
          },
          "position": {"x": 0, "y": 2, "width": 4, "height": 6}
        },
        {
